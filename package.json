{
  "name": "claude-skill-targetable-feedback",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "build:zip": "./scripts/build-zip.sh",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:grade": "vite-node tests/evals/grade.ts --",
    "eval:preview": "vite-node tests/evals/build_preview.ts --",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,html,css,json,md,yml,yaml}": "prettier --write",
    "*.{ts,js}": "oxlint"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.0",
    "@types/node": "^24.0.0",
    "@visill/build": "rc",
    "@visill/sdk": "rc",
    "@visill/test": "rc",
    "husky": "^9.1.0",
    "jsdom": "^25.0.0",
    "lightningcss": "^1.32.0",
    "lint-staged": "^15.2.0",
    "oxlint": "^0.15.0",
    "prettier": "^3.3.0",
    "terser": "^5.48.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.14",
    "vite-node": "^2.1.0",
    "vite-plugin-singlefile": "~2.3.3",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "overrides": {
      "@visill/sdk": "link:../visill/packages/visill",
      "@visill/build": "link:../visill/packages/visill-build",
      "@visill/test": "link:../visill/packages/visill-test"
    }
  }
}
